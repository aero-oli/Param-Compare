{
  "name": "ardupilot-param-compare",
  "version": "1.0.0",
  "private": false,
  "description": "Static ArduPilot parameter comparison tool with an OpenAI-powered parameter assistant.",
  "license": "MIT",
  "author": "ArduPilot Param Compare",
  "main": "electron-main.js",
  "scripts": {
    "check": "node --check app.js && node --check desktop-key-store.js && node --check electron-main.js && node --check server.js",
    "desktop": "electron .",
    "dist": "electron-builder --publish never -c.mac.identity=false",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:mac": "electron-builder --mac --publish never -c.mac.identity=false",
    "dist:win": "electron-builder --win --publish never",
    "pack": "electron-builder --dir -c.win.signAndEditExecutable=false -c.mac.identity=false",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^4.19.2",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ardupilot.paramcompare",
    "productName": "ArduPilot Param Compare",
    "asar": true,
    "files": [
      "assets/**/*",
      "app.js",
      "desktop-key-store.js",
      "electron-main.js",
      "external-navigation.js",
      "index.html",
      "server.js",
      "styles.css",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
